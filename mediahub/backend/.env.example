# Flask Application Configuration Example
PORT=5093
SECRET_KEY=enter-a-highly-secure-secret-key-here
JWT_SECRET_KEY=enter-a-highly-secure-jwt-key-here

# Database Configuration
# Leave blank to use local SQLite development database (mediahub.db)
# Set for production PostgreSQL deployment: e.g. postgresql://user:password@host:port/database
DATABASE_URL=
